{
  "name": "lites-app",
  "version": "1.0.0",
  "private": true,
  "description": "lites DMX Controller — desktop wrapper",
  "author": {
    "name": "lites",
    "email": "lites@localhost"
  },
  "homepage": "https://github.com/lites/lites",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && npx electron dist/main.js",
    "dist": "npm run build && npx electron-builder",
    "dist:mac": "npm run build && npx electron-builder --mac",
    "dist:linux": "npm run build && npx electron-builder --linux",
    "dist:win": "npm run build && npx electron-builder --win",
    "postinstall": "true"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "34.5.8",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.lites.app",
    "electronVersion": "34.5.8",
    "productName": "lites",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "window/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server"
      },
      {
        "from": "../data",
        "to": "data"
      },
      {
        "from": "node_modules/serialport",
        "to": "node_modules/serialport"
      },
      {
        "from": "node_modules/@serialport",
        "to": "node_modules/@serialport"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.entertainment",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "AudioVideo",
      "synopsis": "DMX lighting controller"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "lites"
    }
  }
}
