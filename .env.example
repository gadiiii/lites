# Serial port path for ENTTEC DMX USB Pro
# macOS:   /dev/tty.usbserial-EN??????  (run: ls /dev/tty.usbserial*)
# Linux:   /dev/ttyUSB0                  (run: ls /dev/ttyUSB*)
# Windows: COM3
SERIAL_PORT=/dev/tty.usbserial-EN??????

# DMX output frame rate (max ~44 for ENTTEC Pro)
DMX_FPS=40

# HTTP + WebSocket listen port
WS_PORT=3000

# Path to show data file (relative to server working directory)
SHOW_FILE=../data/show.json
